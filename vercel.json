{
  "version": 2,
  "name": "factory-lw-benchhub",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/data/(.*)",
      "headers": {
        "cache-control": "public, max-age=3600",
        "access-control-allow-origin": "*"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
